{
  "name": "fieldops-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node src/api/app.js",
    "prisma:generate": "prisma generate && prisma generate --schema=prisma/schema.test.prisma",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "seed": "node prisma/seed.js",
    "db:clean": "node prisma/clean.js",
    "pretest": "cross-env TEST_DATABASE_URL=file:./test.db prisma db push --schema=prisma/schema.test.prisma --skip-generate --force-reset",
    "test": "cross-env NODE_ENV=test TEST_DATABASE_URL=file:./test.db jest --runInBand",
    "lint": "eslint src"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prisma": "^5.20.0",
    "supertest": "^6.3.4"
  }
}