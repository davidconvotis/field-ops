// Datasource alterno para tests: SQLite en memoria.
// SQLite no soporta enums nativos en Prisma -> los campos de rol/estado/acción
// se modelan como String, validados en runtime contra backend/src/constants.js.
// El mismo código de servicios funciona contra ambos clientes (JS no tipado
// no distingue enum-nativo vs string a nivel de comparación de valores).
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-test-client"
}

datasource db {
  provider = "sqlite"
  url      = env("TEST_DATABASE_URL")
}

model User {
  id           String  @id @default(uuid())
  role         String
  activo       Boolean @default(true)
  nombre       String
  email        String  @unique
  passwordHash String

  ordersAsClient       Order[]               @relation("ClientOrders")
  ordersAsTechnician   Order[]               @relation("TechnicianOrders")
  executionRecords     ExecutionRecord[]
  auditLogEntries      AuditLogEntry[]
  resolvedOrders       Order[]               @relation("ResolvedByOrders")
  revokedRefreshTokens RevokedRefreshToken[]

  createdAt DateTime @default(now())
}

model RevokedRefreshToken {
  jti       String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  revokedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model Order {
  id           String  @id @default(uuid())
  status       String  @default("sin_asignar")
  clientId     String
  client       User    @relation("ClientOrders", fields: [clientId], references: [id])
  technicianId String?
  technician   User?   @relation("TechnicianOrders", fields: [technicianId], references: [id])
  version      Int     @default(0)

  rejectionReason  String?
  resolvedByUserId String?
  resolvedBy       User?   @relation("ResolvedByOrders", fields: [resolvedByUserId], references: [id])

  createdAt   DateTime  @default(now())
  assignedAt  DateTime?
  submittedAt DateTime?
  resolvedAt  DateTime?

  executionRecord ExecutionRecord?
  auditLogEntries AuditLogEntry[]

  @@index([clientId])
  @@index([technicianId])
  @@index([status])
}

model ExecutionRecord {
  id             String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  technicianId   String
  technician     User     @relation(fields: [technicianId], references: [id])
  notes          String
  idempotencyKey String   @unique
  payloadHash    String
  submittedAt    DateTime @default(now())

  photos EvidencePhoto[]
}

model EvidencePhoto {
  id                 String          @id @default(uuid())
  executionRecordId  String
  executionRecord    ExecutionRecord @relation(fields: [executionRecordId], references: [id])
  mimeType           String
  storageKey         String?
  sizeBytes          Int
  uploadedAt         DateTime        @default(now())
  retentionExpiresAt DateTime

  @@index([executionRecordId])
  @@index([retentionExpiresAt])
}

model AuditLogEntry {
  id                 String   @id @default(uuid())
  orderId            String
  order              Order    @relation(fields: [orderId], references: [id])
  actorUserId        String
  actor              User     @relation(fields: [actorUserId], references: [id])
  action             String
  timestamp          DateTime @default(now())
  metadata           String?
  retentionExpiresAt DateTime

  @@index([orderId])
  @@index([retentionExpiresAt])
}
